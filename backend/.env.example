# ─── Core ───
APP_ENV=local
DATABASE_URL=sqlite:///./data/app.db
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ─── Auth ───
# IMPORTANT: Change this to a strong random secret for production
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=orive-dev-secret-change-in-production

# ─── AI Features ───
# "mock" = sample data (no API key needed), "llm" = real AI
AI_MODE=mock
LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ─── Virtual Try-On (Phase F — future) ───
# Sign up at https://fashn.ai — $0.075/image, no subscription
# FASHN_API_KEY=# ─── Google OAuth (deferred) ───
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# ─── Google Calendar (Phase E — future) ───
# GOOGLE_CALENDAR_CLIENT_ID=
# GOOGLE_CALENDAR_CLIENT_SECRET=

# ─── Weather (Phase E — optional) ───
# Free tier: https://openweathermap.org/api
# WEATHER_API_KEY=

# ─── AWS (production only) ───
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_BUCKET=
# AWS_SES_REGION=us-east-1
